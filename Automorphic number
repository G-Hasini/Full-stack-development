import java.util.Scanner;

class Main{
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);

        System.out.print("Enter number: ");
        int n=sc.nextInt();

        int square=n*n;

        if(square%100==n)
            System.out.println("Automorphic Number");
        else
            System.out.println("Not Automorphic Number");
    }
}
