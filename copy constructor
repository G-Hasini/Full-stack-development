class Student {
    int id;
    String name;
    Student(int id, String name) {
        this.id = id;
        this.name = name;
    }
    Student(Student s) {
        this.id = s.id;
        this.name = s.name;
    }
    void display() {
        System.out.println("ID : " + id);
        System.out.println("Name : " + name);
    }
}
class Main {
    public static void main(String[] args) {
        Student s1 = new Student(101, "Hasini");
        Student s2 = new Student(s1);
        System.out.println("Original ");
        s1.display();
        System.out.println();
        System.out.println("Copy");
        s2.display();
    }
}
